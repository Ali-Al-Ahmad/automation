# Compose-level vars (used for image + interpolation in docker-compose.yml).
# docker compose must be invoked with `--env-file .env_backend` for these to apply.
DOCKER_USERNAME=your-dockerhub-username
IMAGE_TAG=latest

# Postgres — consumed by postgres container and used to build DATABASE_URL.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=automation

# Backend runtime
NODE_ENV=production
PORT=3001
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
CORS_ORIGIN=https://your-frontend-domain.example
