# Backend runtime env — copied to the server as `.env` and consumed by the
# backend container via `env_file: .env` in docker-compose.yml.
# CI renders this file from GitHub Secrets on every deploy.

NODE_ENV=production
PORT=3001

# Built from POSTGRES_* secrets at deploy time. `postgres` is the compose service name.
DATABASE_URL=postgresql://postgres:change-me@postgres:5432/automation?schema=public

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
CORS_ORIGIN=http://localhost:3000
