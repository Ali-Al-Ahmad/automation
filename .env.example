# Copied to the server as `.env`, next to docker-compose.yml.
# CI renders it from GitHub Secrets on every deploy.
# Docker Compose auto-loads this file for both interpolation and the
# backend container's `env_file:` — so manual `docker compose ...` commands
# on the server work without any shell exports.

# --- Compose interpolation (image names + postgres container) ---
DOCKER_USERNAME=your-dockerhub-username
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=automation

# --- Backend runtime ---
NODE_ENV=production
PORT=3001
DATABASE_URL=postgresql://postgres:change-me@postgres:5432/automation?schema=public
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
CORS_ORIGIN=http://localhost:3000
