# Copy to `.env` on the server (CI renders this automatically from GitHub Secrets).
# Docker Compose auto-loads `.env` from this directory for `${VAR}` interpolation
# in docker-compose.yml, and passes interpolated values to container environments.

# --- Image namespace ------------------------------------------------------
DOCKER_USERNAME=your-dockerhub-username
IMAGE_TAG=latest

# --- Postgres -------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=automation

# --- Backend runtime ------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
CORS_ORIGIN=http://localhost:3000
